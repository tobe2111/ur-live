# ============================================
# Environment Variables Template
# Copy this file to .env.local and fill in the values
# NEVER commit .env.local or .env with real secrets!
# ============================================

# ============================================
# Frontend Environment Variables (VITE_*)
# These are embedded into the client bundle at build time
# ============================================

# Kakao OAuth (Frontend)
VITE_KAKAO_REST_API_KEY=your_kakao_rest_api_key_here

# Firebase (Frontend) - Public configuration
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_DATABASE_URL=https://your-project-default-rtdb.asia-southeast1.firebasedatabase.app
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# API Base URL (optional, defaults to current origin)
# VITE_API_BASE_URL=https://your-domain.com

# App Base URL — used for QR code generation in PrismQRCode (mobile RTMP setup)
# Defaults to https://live.ur-team.com if not set
# VITE_APP_BASE_URL=https://your-domain.com

# RTMP / WebSocket Server URL — used by WebStreaming and LiveControlPanel
# Must be a wss:// URL. Defaults to wss://live.ur-team.com
# VITE_RTMP_SERVER_URL=wss://your-domain.com

# Stripe Publishable Key (Global region — VITE_* vars are safe to expose)
# VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Environment Mode
# VITE_ENV=development

# ============================================
# Cloudflare Workers Secrets (wrangler secret put)
# These should NEVER be in .env files - use wrangler CLI
# ============================================

# Toss Payments
# wrangler secret put TOSS_SECRET_KEY
# TOSS_SECRET_KEY=test_sk_...

# Toss Payments Client Key (can be in wrangler.toml as it's client-side)
# TOSS_CLIENT_KEY=test_ck_...

# Firebase Admin SDK (Backend)
# wrangler secret put FIREBASE_PRIVATE_KEY
# FIREBASE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n
# wrangler secret put FIREBASE_CLIENT_EMAIL
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
# wrangler secret put FIREBASE_PROJECT_ID
# FIREBASE_PROJECT_ID=your-project-id

# Kakao OAuth (Backend)
# wrangler secret put KAKAO_REST_API_KEY
# KAKAO_REST_API_KEY=your_kakao_rest_api_key
# wrangler secret put KAKAO_REDIRECT_URI
# KAKAO_REDIRECT_URI=https://your-domain.com/auth/kakao/sync/callback

# Alimtalk API
# wrangler secret put ALIMTALK_API_KEY
# ALIMTALK_API_KEY=your_alimtalk_api_key
# wrangler secret put ALIMTALK_SENDER_KEY
# ALIMTALK_SENDER_KEY=your_alimtalk_sender_key

# JWT Secret
# wrangler secret put JWT_SECRET
# JWT_SECRET=your_long_random_jwt_secret_minimum_32_characters

# Admin Credentials (Backend)
# wrangler secret put ADMIN_EMAIL
# ADMIN_EMAIL=admin@yourdomain.com
# wrangler secret put ADMIN_PASSWORD
# ADMIN_PASSWORD=your_secure_admin_password

# Seller Credentials (Backend)
# wrangler secret put SELLER_EMAIL  
# SELLER_EMAIL=seller@yourdomain.com
# wrangler secret put SELLER_PASSWORD
# SELLER_PASSWORD=your_secure_seller_password

# YouTube API
# wrangler secret put YOUTUBE_API_KEY
# YOUTUBE_API_KEY=your_youtube_api_key

# Stripe (Global region)
# wrangler secret put STRIPE_SECRET_KEY
# STRIPE_SECRET_KEY=sk_live_...
#
# Stripe webhook signing secret (optional, for webhook verification)
# wrangler secret put STRIPE_WEBHOOK_SECRET
# STRIPE_WEBHOOK_SECRET=whsec_...

# ============================================
# Cloudflare Bindings (wrangler.toml)
# These are configured in wrangler.toml
# ============================================

# D1 Database
# [[d1_databases]]
# binding = "DB"
# database_name = "your-database"
# database_id = "your-database-id"

# KV Namespace (if using)
# [[kv_namespaces]]
# binding = "KV"
# id = "your-kv-id"

# R2 Bucket (if using)
# [[r2_buckets]]
# binding = "BUCKET"
# bucket_name = "your-bucket"

# ============================================
# Development Only
# ============================================

# Local Development Database
# DEV_DB_PATH=./.wrangler/state/v3/d1/miniflare-D1DatabaseObject/...

# ============================================
# Security Notes
# ============================================

# 1. NEVER commit files containing real secrets:
#    - .env.local (local development)
#    - .env.production (production secrets)
#    - Any file with actual API keys or passwords

# 2. Use wrangler CLI for Workers secrets:
#    wrangler secret put SECRET_NAME
#    (This stores secrets encrypted in Cloudflare)

# 3. Frontend secrets (VITE_*):
#    - Are embedded in the client bundle
#    - Are visible to users (browser DevTools)
#    - Should ONLY contain non-sensitive config
#    - Examples: API endpoints, public keys, project IDs

# 4. Backend secrets (Workers):
#    - Must use wrangler secret put
#    - Never add to wrangler.toml [vars] section
#    - Examples: secret keys, passwords, private keys

# 5. Rotate secrets regularly:
#    - Service account keys: every 90 days
#    - API keys: every 90 days
#    - Passwords: immediately if compromised

# 6. Use Google Cloud Secret Manager for additional security:
#    - Store ultra-sensitive secrets there
#    - Access via Cloudflare Workers → Google Cloud API
#    - Enables centralized secret rotation

# ============================================
# Quick Setup Guide
# ============================================

# 1. Copy this file:
#    cp .env.example .env.local

# 2. Fill in VITE_* variables in .env.local

# 3. Add Workers secrets via wrangler CLI:
#    wrangler secret put TOSS_SECRET_KEY
#    wrangler secret put FIREBASE_PRIVATE_KEY
#    (etc.)

# 4. Deploy:
#    npm run build
#    npm run deploy

# 5. Verify secrets are loaded:
#    Check worker logs in Cloudflare dashboard
