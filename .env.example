# ============================================
# UR Live 환경 변수 예시
# Week 5 Day 2 - 환경 변수 검증 레이어
# ============================================

# --------------------------------------------
# Firebase 설정 (필수 - 모든 Region)
# --------------------------------------------
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789012
VITE_FIREBASE_APP_ID=1:123456789012:web:abcdef123456
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# --------------------------------------------
# Region 설정 (선택 - 자동 설정됨)
# --------------------------------------------
# VITE_REGION=KR  # 또는 GLOBAL

# --------------------------------------------
# KR 전용 환경 변수
# --------------------------------------------
# Kakao 설정 (KR 필수)
VITE_KAKAO_REST_API_KEY=your_kakao_rest_api_key
VITE_KAKAO_JAVASCRIPT_KEY=your_kakao_javascript_key
VITE_KAKAO_AUTH_URL=/auth/kakao

# Toss 결제 설정 (KR 필수)
VITE_TOSS_CLIENT_KEY=test_gck_docs_Ovk5rk1EwkEbP0W43n07xlzm

# Daum 우편번호 API (KR 선택)
# VITE_DAUM_POSTCODE_KEY=your_daum_postcode_key

# --------------------------------------------
# WORLD 전용 환경 변수
# --------------------------------------------
# Google OAuth 설정 (WORLD 필수)
# VITE_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# Stripe 결제 설정 (WORLD 필수)
# VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxx

# --------------------------------------------
# API 설정 (선택)
# --------------------------------------------
# VITE_API_BASE_URL=https://live.ur-team.com

# --------------------------------------------
# Sentry 설정 (선택)
# --------------------------------------------
# VITE_SENTRY_DSN=https://xxxxxxxxxxxxx@sentry.io/xxxxxxxxxxxxx

# ============================================
# Cloudflare Worker Secrets (wrangler secret put)
# ============================================
# 
# 다음 명령어로 추가:
# wrangler secret put FIREBASE_PROJECT_ID
# wrangler secret put FIREBASE_PRIVATE_KEY
# wrangler secret put FIREBASE_CLIENT_EMAIL
# 
# KR 전용:
# wrangler secret put KAKAO_REST_API_KEY
# wrangler secret put KAKAO_CLIENT_SECRET
# wrangler secret put TOSS_SECRET_KEY
# 
# WORLD 전용:
# wrangler secret put GOOGLE_CLIENT_SECRET
# wrangler secret put STRIPE_SECRET_KEY
# 
# 선택:
# wrangler secret put DISCORD_WEBHOOK_URL
# ============================================
