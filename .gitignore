# v0 runtime files (should only exist in preview, not in git)
__v0_runtime_loader.js
__v0_devtools.tsx
__v0_jsx-dev-runtime.ts

# Common ignores
node_modules/
.next/
.env*.local
.DS_Store

# Test coverage reports
coverage/
*.lcov

# 🔒 CRITICAL: DO NOT ignore these React version protection files
# These files prevent React 19 upgrades that cause forwardRef errors
# - REACT_VERSION_POLICY.md
# - scripts/check-react-version.js
# - scripts/verify-react-version.js
# - .npmrc
# Local development environment variables
.dev.vars
core
core
src/index-api-only.tsx.backup
dist-global/

# Build artifacts (auto-generated, don't track)
dist/
dist/version.json
public/version.json

# Log files (PM2, etc.)
logs/
*.log

# Wrangler temporary files
.wrangler/tmp/

# ⚠️ 보안 파일 (절대 Git에 커밋하지 않음)
scripts/*-generated.sql
scripts/migrate-accounts-generated.sql
*.secret
.env.production
