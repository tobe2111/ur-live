{
  "name": "webapp",
  "type": "module",
  "scripts": {
    "preinstall": "node scripts/check-react-version.cjs || echo 'Warning: React version check script not found'",
    "postinstall": "node scripts/verify-react-version.cjs || echo 'Warning: React verification failed'",
    "prebuild": "node scripts/validate-build.cjs && rm -rf dist && node scripts/update-version.js",
    "build": "NODE_OPTIONS='--max-old-space-size=2048' vite build && vite build --config vite.worker.config.ts && node fix-routes.js && node force-update.js",
    "postbuild": "node scripts/validate-build-output.cjs",
    "dev": "vite",
    "dev:wrangler": "npm run build && wrangler pages dev dist --d1=toss-live-commerce-db --local --ip 0.0.0.0 --port 3000",
    "build:worker": "vite build --config vite.worker.config.ts",
    "preview": "npm run build && wrangler pages dev dist --d1=toss-live-commerce-db --local --ip 0.0.0.0 --port 3000",
    "deploy": "npm run build && wrangler pages deploy dist --project-name ur-live --commit-dirty=true",
    "deploy:prod": "npm run build && wrangler pages deploy dist --project-name ur-live --commit-dirty=true",
    "deploy:safe": "./scripts/safe-deploy.sh preview",
    "deploy:safe:prod": "./scripts/safe-deploy.sh production",
    "deploy:auto": "./deploy.sh",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "clean-port": "fuser -k 3000/tcp 2>/dev/null || true",
    "test": "curl http://localhost:3000",
    "test:env:local": "curl http://localhost:3000/api/test/env",
    "test:env:prod": "curl https://live.ur-team.com/api/test/env",
    "type-check": "tsc --noEmit",
    "check:conflicts": "./scripts/check-naming-conflicts.sh",
    "validate:css": "./scripts/validate-css.sh src/",
    "pre-commit": "npm run type-check && npm run check:conflicts && npm run validate:css && npm run build",
    "db:migrate:local": "wrangler d1 migrations apply toss-live-commerce-db --local",
    "db:migrate:prod": "wrangler d1 migrations apply toss-live-commerce-db",
    "db:seed": "wrangler d1 execute toss-live-commerce-db --local --file=./seed.sql",
    "db:reset": "rm -rf .wrangler/state/v3/d1 && npm run db:migrate:local && npm run db:seed",
    "db:console:local": "wrangler d1 execute toss-live-commerce-db --local",
    "db:console:prod": "wrangler d1 execute toss-live-commerce-db",
    "git:init": "git init && git add . && git commit -m 'Initial commit'",
    "git:commit": "git add . && git commit -m",
    "git:status": "git status",
    "git:log": "git log --oneline",
    "validate": "./scripts/validate-html.sh",
    "pre-deploy": "npm run validate && npm run build"
  },
  "dependencies": {
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@sentry/react": "10.39.0",
    "@sentry/vite-plugin": "5.0.0",
    "@tosspayments/tosspayments-sdk": "^2.5.0",
    "@tsndr/cloudflare-worker-jwt": "3.2.1",
    "axios": "^1.13.4",
    "browser-image-compression": "^2.0.2",
    "embla-carousel-react": "^8.6.0",
    "firebase": "12.9.0",
    "firebase-admin": "13.7.0",
    "hono": "^4.11.7",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-router-dom": "6.28.1",
    "recharts": "^3.7.0",
    "zod": "4.3.6"
  },
  "overrides": {
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "@types/react": "18.3.18",
    "@types/react-dom": "18.3.5"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "engineStrict": true,
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260128.0",
    "@hono/vite-build": "^1.2.0",
    "@hono/vite-cloudflare-pages": "^0.4.3",
    "@hono/vite-dev-server": "^0.18.2",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/react": "18.3.18",
    "@types/react-dom": "18.3.5",
    "@vitejs/plugin-react": "^5.1.3",
    "autoprefixer": "^10.4.24",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.563.0",
    "postcss": "^8.5.6",
    "rollup-plugin-visualizer": "^6.0.5",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^3.4.19",
    "tailwindcss-animate": "^1.0.7",
    "terser": "^5.46.0",
    "typescript": "^5.0.0",
    "vite": "^6.3.5",
    "wrangler": "^4.4.0"
  }
}
