{
  "name": "global-marketplace",
  "version": "1.0.0",
  "description": "Global marketplace with Cloudflare Worker + React + D1 + Toss Payments",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:worker\" \"npm run dev:client\"",
    "dev:worker": "wrangler dev --local",
    "dev:client": "vite",
    "build": "npm run build:client && npm run build:worker && npm run build:prepare",
    "build:client": "vite build",
    "build:worker": "node scripts/build-worker.js",
    "build:prepare": "cp dist/_worker.js dist/client/_worker.js && (cp dist/_routes.json dist/client/_routes.json 2>/dev/null || cp public/_routes.json dist/client/_routes.json)",
    "deploy": "npm run build:client && wrangler deploy",
    "app:sync": "npm run build && npx cap sync",
    "app:android": "npm run app:sync && npx cap open android",
    "app:ios": "npm run app:sync && npx cap open ios",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "db:migrate": "wrangler d1 execute toss-live-commerce-db --local --file=migrations/001_initial.sql",
    "db:migrate:all": "node scripts/migrate-all.js",
    "db:migrate:all:prod": "node scripts/migrate-all.js --prod",
    "db:migrate:prod": "wrangler d1 execute toss-live-commerce-db --file=migrations/001_initial.sql",
    "db:seed": "wrangler d1 execute toss-live-commerce-db --local --file=migrations/002_seed.sql",
    "db:reset": "rm -rf .wrangler/state/v3/d1 && npm run db:migrate:all && npm run db:seed",
    "type-check": "tsc --noEmit",
    "type-check:worker": "tsc --noEmit --project tsconfig.worker.json",
    "validate:routes": "bash scripts/validate-routes.sh",
    "precommit": "npm run validate:routes && npm run type-check:worker"
  },
  "dependencies": {
    "@capacitor-community/admob": "6.2.0",
    "@capacitor/android": "8.3.0",
    "@capacitor/app": "8.1.0",
    "@capacitor/browser": "8.0.3",
    "@capacitor/cli": "8.3.0",
    "@capacitor/core": "8.3.0",
    "@capacitor/haptics": "8.0.2",
    "@capacitor/ios": "8.3.0",
    "@capacitor/keyboard": "8.0.2",
    "@capacitor/push-notifications": "8.0.3",
    "@capacitor/share": "8.0.1",
    "@capacitor/splash-screen": "8.0.1",
    "@capacitor/status-bar": "8.0.2",
    "@hono/swagger-ui": "0.6.1",
    "@radix-ui/react-checkbox": "1.3.3",
    "@radix-ui/react-separator": "1.1.8",
    "@radix-ui/react-slot": "1.2.4",
    "@sentry/react": "10.43.0",
    "@stripe/react-stripe-js": "5.6.1",
    "@stripe/stripe-js": "8.9.0",
    "@tanstack/react-query": "^5.56.2",
    "@tosspayments/tosspayments-sdk": "2.6.0",
    "@tsndr/cloudflare-worker-jwt": "3.2.1",
    "axios": "1.13.6",
    "bcryptjs": "2.4.3",
    "browser-image-compression": "2.0.2",
    "class-variance-authority": "0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "0.45.1",
    "embla-carousel-react": "8.6.0",
    "firebase": "12.10.0",
    "firebase-admin": "13.7.0",
    "hono": "^4.5.0",
    "i18next-browser-languagedetector": "8.2.1",
    "i18next-http-backend": "3.0.2",
    "jose": "6.2.1",
    "jsbarcode": "3.12.3",
    "lucide-react": "^0.441.0",
    "qrcode.react": "4.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-helmet-async": "3.0.0",
    "react-hook-form": "^7.53.0",
    "react-i18next": "16.5.8",
    "react-router-dom": "^6.26.2",
    "recharts": "3.8.0",
    "tailwind-merge": "3.5.0",
    "zod": "^3.23.8",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240925.0",
    "@playwright/test": "^1.47.0",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/bcryptjs": "2.4.6",
    "@types/node": "^22.5.5",
    "@types/qrcode.react": "1.0.5",
    "@types/react": "^18.3.8",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.0.1",
    "esbuild": "0.27.4",
    "eslint-plugin-import": "2.32.0",
    "jsdom": "28.1.0",
    "msw": "2.12.10",
    "postcss": "^8.4.45",
    "tailwindcss": "^3.4.11",
    "terser": "5.46.1",
    "typescript": "^5.5.4",
    "vite": "^5.4.3",
    "vitest": "^2.1.1",
    "wrangler": "^3.75.0"
  }
}
