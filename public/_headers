# Security Headers for all routes
/*
  # Cache Control
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0

  # CSP는 Worker (src/worker/index.ts) 에서 동적으로 발급한다.
  # 여기서 중복 선언하면 정책이 충돌·병합되어 의도치 않게 느슨해질 수 있음.
  # (하드닝된 CSP · CSP reporting · nonce/hash 정책은 Worker 쪽에서 단일 관리)

  # Prevent MIME type sniffing
  X-Content-Type-Options: nosniff

  # Clickjacking Protection (SAMEORIGIN — live 페이지 임베드 허용)
  X-Frame-Options: SAMEORIGIN

  # Referrer Policy
  Referrer-Policy: strict-origin-when-cross-origin

  # Permissions Policy
  # 🛡️ 2026-04-27: geolocation=(self) — MainHomePage 의 GPS 자동 지역 감지 허용
  Permissions-Policy: geolocation=(self), microphone=(), camera=(self), payment=(self), usb=(), interest-cohort=()

  # Strict Transport Security (HSTS)
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload

  # 🛡️ 2026-04-29: Cross-Origin-Opener-Policy — Spectre/사이드채널 방어.
  #   same-origin-allow-popups 로 OAuth popup (Google/Kakao consent) 호환 유지.
  Cross-Origin-Opener-Policy: same-origin-allow-popups

# Cache control for static assets
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# No cache for HTML files
/*.html
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0

# API routes - no cache + additional security
/api/*
  Cache-Control: no-store, no-cache, must-revalidate
  Pragma: no-cache
  Expires: 0
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY

# Auth routes - no cache + strict security
/auth/*
  Cache-Control: no-store, no-cache, must-revalidate
  Pragma: no-cache
  Expires: 0
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: no-referrer

# PWA manifest - MIME type (avoids "Manifest: Line: 1 Syntax error" in Chrome)
/manifest.webmanifest
  Content-Type: application/manifest+json; charset=utf-8
  Cache-Control: public, max-age=3600

/*.webmanifest
  Content-Type: application/manifest+json; charset=utf-8

# 🛡️ 2026-04-30: Universal Link / App Link 파일 (Apple/Google 검증)
#   apple-app-site-association: 확장자 없음, application/json 필수
#   assetlinks.json: 동일
/.well-known/apple-app-site-association
  Content-Type: application/json
  Cache-Control: public, max-age=86400

/.well-known/assetlinks.json
  Content-Type: application/json
  Cache-Control: public, max-age=86400
