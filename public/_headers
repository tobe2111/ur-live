# Security Headers for all routes
/*
  # Cache Control
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0

  # CSP — Cloudflare _headers 2000자 제한으로 와일드카드 사용
  Content-Security-Policy: default-src 'self' 'unsafe-inline' 'unsafe-eval' data: blob:; script-src 'self' 'unsafe-inline' 'unsafe-eval' blob: https: http:; style-src 'self' 'unsafe-inline' data: https:; font-src 'self' data: https:; img-src 'self' data: blob: https: http:; connect-src 'self' https: wss:; frame-src 'self' https:; worker-src 'self' blob:; manifest-src 'self'; media-src 'self' data: blob: https:; object-src 'none'; base-uri 'self'; form-action 'self' https://kauth.kakao.com;

  # XSS Protection
  X-XSS-Protection: 1; mode=block

  # Prevent MIME type sniffing
  X-Content-Type-Options: nosniff

  # Clickjacking Protection (SAMEORIGIN — live 페이지 임베드 허용)
  X-Frame-Options: SAMEORIGIN

  # Referrer Policy
  Referrer-Policy: strict-origin-when-cross-origin

  # Permissions Policy
  Permissions-Policy: geolocation=(), microphone=(), camera=(), payment=(self), usb=(), interest-cohort=()

  # Strict Transport Security (HSTS)
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload

# Cache control for static assets
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# No cache for HTML files
/*.html
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0

# API routes - no cache + additional security
/api/*
  Cache-Control: no-store, no-cache, must-revalidate
  Pragma: no-cache
  Expires: 0
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY

# Auth routes - no cache + strict security
/auth/*
  Cache-Control: no-store, no-cache, must-revalidate
  Pragma: no-cache
  Expires: 0
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: no-referrer
