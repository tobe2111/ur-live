# Cloudflare Pages Static Asset Caching
# SPA 최적화: HTML은 캐싱 안함, JS/CSS는 강력하게 캐싱

# SPA Entry Point (index.html) - NO CACHE
/
  Cache-Control: no-cache, no-store, must-revalidate
  CDN-Cache-Control: no-store

# HTML files - NO CACHE (SPA uses client-side routing)
/*.html
  Cache-Control: no-cache, no-store, must-revalidate
  CDN-Cache-Control: no-store

# JavaScript bundles (with hash) - CACHE FOREVER
/assets/*.js
  Cache-Control: public, max-age=31536000, immutable
  CDN-Cache-Control: public, max-age=31536000

# CSS bundles (with hash) - CACHE FOREVER
/assets/*.css
  Cache-Control: public, max-age=31536000, immutable
  CDN-Cache-Control: public, max-age=31536000

# Static files in /static
/static/*
  Cache-Control: public, max-age=31536000, immutable
  CDN-Cache-Control: public, max-age=31536000

# Images
/images/*
  Cache-Control: public, max-age=31536000, immutable
  CDN-Cache-Control: public, max-age=31536000

# Fonts
/*.woff
  Cache-Control: public, max-age=31536000, immutable
  CDN-Cache-Control: public, max-age=31536000

/*.woff2
  Cache-Control: public, max-age=31536000, immutable
  CDN-Cache-Control: public, max-age=31536000

# Favicon
/favicon.svg
  Cache-Control: public, max-age=86400
  CDN-Cache-Control: public, max-age=86400

# API routes (no caching)
/api/*
  Cache-Control: no-cache, no-store, must-revalidate
  CDN-Cache-Control: no-store

# Auth routes (no caching)
/auth/*
  Cache-Control: no-cache, no-store, must-revalidate
  CDN-Cache-Control: no-store
