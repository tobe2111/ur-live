# Security Headers for all routes
/*
  # Cache Control
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0

  # CSP는 Worker (src/worker/index.ts) 에서 동적으로 발급한다.
  # 여기서 중복 선언하면 정책이 충돌·병합되어 의도치 않게 느슨해질 수 있음.
  # (하드닝된 CSP · CSP reporting · nonce/hash 정책은 Worker 쪽에서 단일 관리)

  # Prevent MIME type sniffing
  X-Content-Type-Options: nosniff

  # Clickjacking Protection (SAMEORIGIN — live 페이지 임베드 허용)
  X-Frame-Options: SAMEORIGIN

  # Referrer Policy
  Referrer-Policy: strict-origin-when-cross-origin

  # Permissions Policy
  Permissions-Policy: geolocation=(), microphone=(), camera=(), payment=(self), usb=(), interest-cohort=()

  # Strict Transport Security (HSTS)
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload

# Cache control for static assets
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# No cache for HTML files
/*.html
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0

# API routes - no cache + additional security
/api/*
  Cache-Control: no-store, no-cache, must-revalidate
  Pragma: no-cache
  Expires: 0
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY

# Auth routes - no cache + strict security
/auth/*
  Cache-Control: no-store, no-cache, must-revalidate
  Pragma: no-cache
  Expires: 0
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: no-referrer
