# =================================
# Environment Variables Template
# =================================
# 
# This file contains ALL environment variables required for the application.
# Copy this file to `.dev.vars` for local development.
# For production, set these as Cloudflare Secrets using:
#   npx wrangler secret put VARIABLE_NAME --project-name PROJECT_NAME
#

# =================================
# Kakao Login Configuration
# =================================

# Kakao JavaScript Key (Frontend SDK)
# Get from: https://developers.kakao.com/console/app/{APP_ID}/config/platform
KAKAO_JS_KEY=your_kakao_js_key_here

# Kakao REST API Key (Backend API)
# Get from: https://developers.kakao.com/console/app/{APP_ID}/config/appKey
KAKAO_REST_API_KEY=your_kakao_rest_api_key_here

# Note: Kakao Sync doesn't require Redirect URI or Client Secret
# Authentication is handled by Kakao SDK in the browser

# =================================
# Payment Gateway Configuration
# =================================

# Payment Provider Type
# Options: 'mock' | 'toss' | 'portone'
# Default: 'mock' (for development without real payment)
PAYMENT_PROVIDER=mock

# --- Toss Payments Configuration (when using PAYMENT_PROVIDER=toss) ---
# Get from: https://docs.tosspayments.com/guides/using-api/getting-started#API-key
# TOSS_CLIENT_KEY=test_ck_...        # Frontend client key
# TOSS_SECRET_KEY=test_sk_...        # Backend secret key
# TOSS_MERCHANT_ID=...               # Your merchant ID

# --- PortOne Configuration (when using PAYMENT_PROVIDER=portone) ---
# Get from: https://admin.portone.io/
# PORTONE_API_KEY=...                # API Key
# PORTONE_API_SECRET=...             # API Secret  
# PORTONE_STORE_ID=...               # Store ID
# PORTONE_CHANNEL_KEY=...            # Channel Key (formerly IMP)

# =================================
# Application Configuration
# =================================

# Application Environment
# Options: 'development' | 'production'
NODE_ENV=development

# =================================
# Database Configuration
# =================================

# D1 Database bindings are configured in wrangler.jsonc
# No environment variables needed for D1

# =================================
# Security Configuration
# =================================

# Session Secret (for generating session tokens)
# Generate a random string: openssl rand -hex 32
# SESSION_SECRET=your_random_secret_here

# CORS Allowed Origins (comma-separated)
# Example: https://yourdomain.com,https://admin.yourdomain.com
# CORS_ORIGINS=*

# =================================
# Third-Party Services
# =================================

# Firebase Configuration (for chat functionality)
# Get from: Firebase Console > Project Settings > Your apps > Web app
# FIREBASE_API_KEY=...
# FIREBASE_AUTH_DOMAIN=...
# FIREBASE_PROJECT_ID=...
# FIREBASE_STORAGE_BUCKET=...
# FIREBASE_MESSAGING_SENDER_ID=...
# FIREBASE_APP_ID=...

# =================================
# Email/SMS Configuration (optional)
# =================================

# Email Service (SendGrid, Mailgun, etc.)
# EMAIL_SERVICE_API_KEY=...
# EMAIL_FROM_ADDRESS=...

# SMS Service (Twilio, etc.)
# SMS_SERVICE_API_KEY=...
# SMS_FROM_NUMBER=...

# =================================
# Monitoring & Analytics (optional)
# =================================

# Sentry (Error monitoring)
# SENTRY_DSN=...
# VITE_SENTRY_DSN=...               # Frontend (브라우저 에러 추적)

# Google Analytics
# GA_MEASUREMENT_ID=...

# =================================
# Discord 알림 (Cron 실패 / Reconciliation 이상)
# =================================
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# =================================
# 푸시 알림 (PWA — VAPID)
# =================================
# 생성: npx web-push generate-vapid-keys
# VITE_VAPID_PUBLIC_KEY=...         # 프론트엔드 (subscribe 시 사용)
# VAPID_PRIVATE_KEY=...             # 백엔드 (push 발송 시 사용)

# =================================
# Resend (자동 월간 리포트 메일)
# =================================
# RESEND_API_KEY=re_...
# RESEND_FROM=noreply@ur-team.com

# =================================
# TikTok 통합 (T1 — 2026-04-26 추가)
# =================================
# 발급: https://developers.tiktok.com → Manage apps → Create an app
# Redirect URI: https://live.ur-team.com/seller/tiktok/callback
# Scopes: user.info.basic, user.info.profile, video.list
# TIKTOK_CLIENT_KEY=...
# TIKTOK_CLIENT_SECRET=...

# =================================
# 신규 secrets — 2026-04-27 추가
# =================================
# 시크릿 회전 시 generated 값 (rotate-secrets.mjs 실행)
# JWT_SECRET=...                    # 위에 이미 정의됨
# REFRESH_TOKEN_SECRET=...          # JWT 와 별도, 회전 시 함께
# INTERNAL_CRON_TOKEN=...           # /api/_internal/* endpoint 보호
# TOSS_WEBHOOK_SECRET=...           # 토스 대시보드 보안 키와 동일

# =================================
# 환경 식별 (필수)
# =================================
# ENVIRONMENT=production            # production | development
# REGION=KR                         # KR | GLOBAL (cosmetic)
