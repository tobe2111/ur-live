{
  "version": 1,
  "description": "Route static assets directly, everything else to Worker for SPA routing",
  "include": [
    "/*"
  ],
  "exclude": [
    "/client/assets/*",
    "/assets/*",
    "/static/*",
    "/locales/*",
    "/*.js",
    "/*.css",
    "/*.map",
    "/*.png",
    "/*.jpg",
    "/*.jpeg",
    "/*.gif",
    "/*.svg",
    "/*.ico",
    "/*.woff",
    "/*.woff2",
    "/*.ttf",
    "/*.eot",
    "/*.webmanifest",
    "/*.txt",
    "/*.br",
    "/*.gz"
  ]
}
