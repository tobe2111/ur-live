# 🔒 NPM Configuration - React Version Protection
# This file ensures consistent dependency resolution

# Save exact versions (no ^ or ~ prefixes)
save-exact=true

# Use package-lock.json for consistent installs
package-lock=true

# Strict engine checking
engine-strict=true

# Prevent automatic major version updates
save-prefix=

# Always respect package.json overrides
legacy-peer-deps=false
