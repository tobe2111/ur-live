# 한국 버전 환경 변수 (템플릿)
# 실제 값을 입력하여 .env.kr 파일을 생성하세요

# ============================================
# 🌍 지역 설정
# ============================================
VITE_REGION=KR
VITE_DEFAULT_LANGUAGE=ko
VITE_API_BASE_URL=https://live.ur-team.com

# ============================================
# 🔥 Firebase 설정 (필수)
# ============================================
# Firebase Console: https://console.firebase.google.com/
# Project Settings > General > Your apps
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789012
VITE_FIREBASE_APP_ID=1:123456789012:web:abcdef123456
VITE_FIREBASE_MEASUREMENT_ID=G-ABCDEF1234
VITE_FIREBASE_DATABASE_URL=https://your-project-default-rtdb.asia-southeast1.firebasedatabase.app

# ============================================
# 🟡 Kakao 설정 (필수 - KR only)
# ============================================
# Kakao Developers: https://developers.kakao.com/console/app
# My Application > App Keys
VITE_KAKAO_APP_KEY=your_kakao_app_key_here
VITE_KAKAO_REST_API_KEY=your_kakao_rest_api_key_here
VITE_KAKAO_JAVASCRIPT_KEY=your_kakao_javascript_key_here

# ============================================
# 💳 Toss Payments 설정 (필수 - KR only)
# ============================================
# Toss Payments: https://developers.tosspayments.com/my/api-keys
# Use test key for development, live key for production
VITE_TOSS_CLIENT_KEY=test_gck_YOUR_TEST_CLIENT_KEY_HERE

# ============================================
# 📧 기타 설정 (선택)
# ============================================
# Sentry DSN (에러 모니터링)
# VITE_SENTRY_DSN=https://your-sentry-dsn-here

# ============================================
# 💡 사용 방법
# ============================================
# 1. 이 파일을 .env.kr 로 복사
# 2. 위의 placeholder 값들을 실제 키로 교체
# 3. .env.kr 파일은 절대 Git에 커밋하지 마세요 (.gitignore에 포함됨)
#
# 빠른 시작:
#   cp .env.kr.example .env.kr
#   # 실제 키 값 입력
#   npm run dev:kr
