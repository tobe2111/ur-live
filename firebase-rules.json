{
  "rules": {
    "streams": {
      "$streamId": {
        ".read": true,
        ".write": "auth != null && (auth.token.admin === true || auth.token.seller === true)",
        ".validate": "newData.hasChildren(['id', 'status'])",
        "id": {
          ".validate": "newData.isNumber()"
        },
        "status": {
          ".validate": "newData.isString() && (newData.val() === 'live' || newData.val() === 'scheduled' || newData.val() === 'ended')"
        },
        "current_product_id": {
          ".validate": "newData.isNumber() || newData.val() === null"
        },
        "viewer_count": {
          ".validate": "newData.isNumber()"
        },
        "updated_at": {
          ".validate": "newData.isNumber()"
        }
      }
    },
    "products": {
      "$productId": {
        ".read": true,
        ".write": "auth != null && (auth.token.admin === true || auth.token.seller === true)",
        ".validate": "newData.hasChildren(['id', 'stock'])",
        "id": {
          ".validate": "newData.isNumber()"
        },
        "stock": {
          ".validate": "newData.isNumber() && newData.val() >= 0"
        },
        "name": {
          ".validate": "newData.isString()"
        },
        "price": {
          ".validate": "newData.isNumber() && newData.val() > 0"
        },
        "updated_at": {
          ".validate": "newData.isNumber()"
        }
      }
    },
    "stream_products": {
      "$streamId": {
        ".read": true,
        ".write": "auth != null && (auth.token.admin === true || auth.token.seller === true)",
        "products": {
          "$productId": {
            ".validate": "newData.hasChildren(['id', 'stock'])",
            "stock": {
              ".validate": "newData.isNumber() && newData.val() >= 0"
            }
          }
        }
      }
    },
    "chats": {
      "$streamId": {
        ".read": true,
        ".write": true,
        "$messageId": {
          ".validate": "newData.hasChildren(['username', 'text', 'timestamp'])",
          "username": {
            ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 50"
          },
          "text": {
            ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 500"
          },
          "timestamp": {
            ".validate": "newData.isNumber()"
          },
          "isSystem": {
            ".validate": "newData.isBoolean()"
          }
        }
      }
    },
    ".read": false,
    ".write": false
  }
}
